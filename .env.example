# Database
# For PostgreSQL + pgvector:
# DATABASE_URL=postgresql+psycopg://borg:borg@localhost:5432/borg
# Default for local prototype without Postgres:
DATABASE_URL=sqlite:///data/borg.db

# Web auth
BORG_PASSWORD=change_me

# SMB inventory / assimilation
BORG_SMB_HOST=10.0.0.100
BORG_SMB_SHARE=projects
BORG_SMB_USERNAME=theone
BORG_SMB_PASSWORD=your_smb_password_here
BORG_SMB_DOMAIN=

# LLM fallback (optional)
OPENAI_API_KEY=

# Pollinations image generation (optional; without a key requests are rate-limited)
POLLINATIONS_API_KEY=

# Databricks export (optional)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=

# RTSP camera credentials (optional)
# By camera name from config/borg.yaml (e.g. front, back)
BORG_CAMERA_FRONT_USERNAME=admin
BORG_CAMERA_FRONT_PASSWORD=
BORG_CAMERA_BACK_USERNAME=admin
BORG_CAMERA_BACK_PASSWORD=

# Fallback by index if named env vars are not set
BORG_CAMERA_1_USERNAME=admin
BORG_CAMERA_1_PASSWORD=
BORG_CAMERA_2_USERNAME=admin
BORG_CAMERA_2_PASSWORD=
